generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  price       Decimal     @db.Decimal(10, 2)
  description String
  images      String[]
  stock       Int         @default(0)
  sizes       String[]
  colors      String[]
  sku         String      @unique
  active      Boolean     @default(true)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Order {
  id             String      @id @default(cuid())
  number         String      @unique
  customerName   String
  email          String
  whatsapp       String?
  cpf            String?
  cep            String
  address        String
  numberAddress  String
  complement     String?
  neighborhood   String
  city           String
  state          String
  subtotal       Decimal     @db.Decimal(10, 2)
  shipping       Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  status         OrderStatus @default(AWAITING_PAYMENT)
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  name          String
  sku           String
  size          String
  color         String
  customization String?
  quantity      Int
  unitPrice     Decimal  @db.Decimal(10, 2)
  total         Decimal  @db.Decimal(10, 2)
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String
  order              Order         @relation(fields: [orderId], references: [id])
  provider           String        @default("mercado_pago")
  providerPaymentId  String?
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  qrCode             String?
  qrCodeBase64       String?
  boletoUrl          String?
  installments       Int?
  rawResponse        Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

enum UserRole {
  ADMIN
  CUSTOMER
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
}
